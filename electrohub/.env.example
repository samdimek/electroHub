# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=ElectroHub

# ── Database (Postgres — Neon, Vercel Postgres, or self-hosted) ───────
DATABASE_URL="postgresql://user:password@localhost:5432/electrohub?schema=public"

# ── Auth / Sessions ─────────────────────────────────────────────────
# 32+ byte random secret used to sign session JWTs. Generate with:
#   openssl rand -base64 48
AUTH_SECRET="replace-with-a-long-random-string"
SESSION_COOKIE_NAME="eh_session"
CSRF_COOKIE_NAME="eh_csrf"
# Only needed if you change CSRF_COOKIE_NAME above — must match it exactly
# (this one is exposed to the browser deliberately; the cookie name itself
# isn't a secret, only the token value is).
NEXT_PUBLIC_CSRF_COOKIE_NAME="eh_csrf"

# ── Redis (Upstash — serverless REST Redis, works on Vercel) ─────────
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxx"

# ── S3-compatible object storage ──────────────────────────────────────
S3_REGION="us-east-1"
S3_BUCKET="electrohub-media"
S3_ACCESS_KEY_ID="xxxx"
S3_SECRET_ACCESS_KEY="xxxx"
# Optional: only set for non-AWS S3-compatible providers (R2, MinIO, etc.)
S3_ENDPOINT=""
CDN_HOSTNAME="cdn.example.com"

# ── Resend (transactional email) ───────────────────────────────────
RESEND_API_KEY="re_xxxx"
RESEND_FROM_EMAIL="ElectroHub <orders@yourdomain.com>"

# ── Sentry (monitoring / error tracking) ───────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"
SENTRY_ORG="your-org"
SENTRY_PROJECT="electrohub"
SENTRY_AUTH_TOKEN="xxxx"

# ── Stripe (secure payment tokenization — no card data ever touches our servers) ─
STRIPE_SECRET_KEY="sk_test_xxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxx"

# ── Cloudflare Turnstile (CAPTCHA) ─────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ── Backups ─────────────────────────────────────────────────────────
# Only needed if you run the optional backup script (scripts/backup.sh)
# against a self-hosted Postgres instance. Managed providers (Neon,
# Vercel Postgres, RDS) handle point-in-time recovery automatically.
BACKUP_S3_BUCKET="electrohub-backups"
